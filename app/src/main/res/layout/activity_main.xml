<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EchoSense Intelligence"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnToggleEngine"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Stop Engine"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnAutoTune"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Auto-Tune"
                android:backgroundTint="#FF9800" />
        </LinearLayout>

        <!-- New: Power & Continuity Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <CheckBox
                android:id="@+id/cbKeepScreenOn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Keep Screen On"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="16dp" />

            <Button
                android:id="@+id/btnDimScreen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dim Mode"
                android:textSize="12sp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:textColor="#BBBBBB" />
        </LinearLayout>

        <com.echosense.app.FrequencyVisualizerView
            android:id="@+id/visualizerView"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="#1E1E1E"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Live Transcription"
            android:textColor="#BBBBBB"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="#000000"
            android:padding="12dp"
            android:layout_marginBottom="16dp">
            <TextView
                android:id="@+id/tvTranscription"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Waiting for speech..."
                android:textColor="#00FF00"
                android:textSize="18sp"
                android:scrollbars="vertical" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Input Level"
            android:textColor="#BBBBBB"
            android:layout_marginBottom="4dp" />
        <ProgressBar
            android:id="@+id/progressBarVolume"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#4CAF50"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mic Sensitivity (Pre-Amp)"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />
        <SeekBar
            android:id="@+id/seekBarPreAmp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="10"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Voice Clarity Boost"
            android:textColor="#4FC3F7"
            android:textStyle="bold" />
        <SeekBar
            android:id="@+id/seekBarVoiceBoost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="0"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Master Output Gain"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />
        <SeekBar
            android:id="@+id/seekBarMasterGain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="200"
            android:progress="4"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Noise Gate Threshold"
            android:textColor="#FFFFFF" />
        <SeekBar
            android:id="@+id/seekBarNoiseGate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="0"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Band 1: Low (200Hz)"
            android:textColor="#FFFFFF" />
        <SeekBar
            android:id="@+id/seekBarBand1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="200"
            android:progress="100"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Band 2: Low-Mid (500Hz)"
            android:textColor="#FFFFFF" />
        <SeekBar
            android:id="@+id/seekBarBand2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="200"
            android:progress="100"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Band 3: Mid (1.5kHz)"
            android:textColor="#FFFFFF" />
        <SeekBar
            android:id="@+id/seekBarBand3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="200"
            android:progress="100"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Band 4: High-Mid (3kHz)"
            android:textColor="#FFFFFF" />
        <SeekBar
            android:id="@+id/seekBarBand4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="200"
            android:progress="100"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Band 5: High (6kHz)"
            android:textColor="#FFFFFF" />
        <SeekBar
            android:id="@+id/seekBarBand5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="200"
            android:progress="100"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</ScrollView>