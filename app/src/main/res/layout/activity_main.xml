<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="EchoSense AI"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />
            <Button
                android:id="@+id/btnExitApp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Exit"
                android:textSize="12sp"
                android:backgroundTint="#D32F2F" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnToggleEngine"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Stop Engine"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnAutoTune"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="AI Auto-Tune"
                android:backgroundTint="#FF9800" />
        </LinearLayout>

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/swTargetLock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Target Lock (Crowd Isolation)"
            android:textColor="#FF4081"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI Speaker Isolation"
                android:textColor="#B2FF59"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupSpeaker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true">
                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSpeakerNone"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="None"
                    android:checked="true"
                    android:textColor="#FFFFFF" />
            </com.google.android.material.chip.ChipGroup>
        </LinearLayout>

        <!-- Spectral AI Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Spectral AI Noise Killer"
            android:textColor="#BBDEFB"
            android:textStyle="bold" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <Button
                android:id="@+id/btnLearnNoise"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Learn Noise"
                android:textSize="12sp"
                android:backgroundTint="#607D8B"
                android:layout_marginEnd="16dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Strength:"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="8dp" />
            <SeekBar
                android:id="@+id/seekBarSpectralReduction"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="0" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Neural Spectral Gate (Per-band Isolation)"
            android:textColor="#BBDEFB"
            android:textStyle="bold" />
        <SeekBar
            android:id="@+id/seekBarSpectralGate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="0"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Spectral De-reverberation (Clean Echo)"
            android:textColor="#BBBBBB"
            android:textSize="12sp" />
        <SeekBar
            android:id="@+id/seekBarDereverb"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="0"
            android:layout_marginBottom="16dp" />
        <!-- Profiles Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Audio Profile"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:singleSelection="true">
            <com.google.android.material.chip.Chip
                android:id="@+id/chipProfileVoice"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Voice"
                android:textColor="#FFFFFF" />
            <com.google.android.material.chip.Chip
                android:id="@+id/chipProfileMusic"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Music"
                android:textColor="#FFFFFF" />
            <com.google.android.material.chip.Chip
                android:id="@+id/chipProfileTV"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TV"
                android:textColor="#FFFFFF" />
            <com.google.android.material.chip.Chip
                android:id="@+id/chipProfileCustom"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Custom"
                android:checked="true"
                android:textColor="#FFFFFF" />
        </com.google.android.material.chip.ChipGroup>

        <!-- Mic Selection -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mic Source:"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="12dp" />
            <RadioGroup
                android:id="@+id/rgMicSource"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <RadioButton
                    android:id="@+id/rbMicAuto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Auto"
                    android:textColor="#FFFFFF"
                    android:checked="true" />
                <RadioButton
                    android:id="@+id/rbMicPhone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phone"
                    android:textColor="#FFFFFF" />
                <RadioButton
                    android:id="@+id/rbMicWatch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Watch"
                    android:textColor="#FFFFFF" />
            </RadioGroup>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutWatchGain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp"
            android:visibility="gone">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Watch Mic Boost (AI Remote)"
                android:textColor="#FFEB3B"
                android:textStyle="bold" />
            <SeekBar
                android:id="@+id/seekBarWatchGain"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="40" />
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/swSensorFusion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sensor Fusion (Ambient subtraction)"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutBluetoothOpt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp"
            android:visibility="visible">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Wireless ANC Mode:"
                android:textColor="#4CAF50"
                android:textStyle="bold"
                android:layout_marginEnd="12dp" />
            <Switch
                android:id="@+id/swBluetoothAnc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <CheckBox
                android:id="@+id/cbKeepScreenOn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Keep Screen On"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="16dp" />

            <Button
                android:id="@+id/btnDimScreen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dim Mode"
                android:textSize="12sp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:textColor="#BBBBBB" />
        </LinearLayout>

        <com.echosense.app.FrequencyVisualizerView
            android:id="@+id/visualizerView"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="#1E1E1E"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Live Transcription"
            android:textColor="#BBBBBB"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="#000000"
            android:padding="12dp"
            android:layout_marginBottom="8dp">
            <TextView
                android:id="@+id/tvTranscription"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Waiting for speech..."
                android:textColor="#00FF00"
                android:textSize="18sp"
                android:scrollbars="vertical" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">
            <Button
                android:id="@+id/btnSummarize"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Summarize AI"
                android:backgroundTint="#673AB7"
                android:layout_marginEnd="8dp" />
            <Button
                android:id="@+id/btnClearHistory"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Clear History"
                android:backgroundTint="#424242" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Input Level"
            android:textColor="#BBBBBB"
            android:layout_marginBottom="4dp" />
        <ProgressBar
            android:id="@+id/progressBarVolume"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#4CAF50"
            android:layout_marginBottom="16dp" />

        <!-- AI Voice Boost Slider -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI Voice Clarity Boost"
            android:textColor="#4FC3F7"
            android:textStyle="bold" />
        <SeekBar
            android:id="@+id/seekBarVoiceBoost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="0"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mic Sensitivity (Pre-Amp)"
            android:textColor="#FFFFFF" />
        <SeekBar
            android:id="@+id/seekBarPreAmp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="10"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Master Output Gain"
            android:textColor="#FFFFFF" />
        <SeekBar
            android:id="@+id/seekBarMasterGain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="200"
            android:progress="10"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fan Killer (HPF Cutoff)"
            android:textColor="#FFCA28"
            android:textStyle="bold" />
        <SeekBar
            android:id="@+id/seekBarHpf"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="30"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hiss Killer (LPF Cutoff)"
            android:textColor="#E1F5FE"
            android:textStyle="bold" />
        <SeekBar
            android:id="@+id/seekBarLpf"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="80"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Keyboard Click Killer (Transient Suppressor)"
            android:textColor="#FFEB3B"
            android:textStyle="bold" />
        <SeekBar
            android:id="@+id/seekBarTransient"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="0"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Clap Protection (Sudden Noise Limiter)"
            android:textColor="#FF5252"
            android:textStyle="bold" />
        <SeekBar
            android:id="@+id/seekBarLimiter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="90"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Noise Gate Threshold"
            android:textColor="#FFFFFF" />
        <SeekBar
            android:id="@+id/seekBarNoiseGate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="0"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI Multi-band Dynamics (Speech Focus)"
            android:textColor="#81D4FA"
            android:textStyle="bold" />
        <SeekBar
            android:id="@+id/seekBarMbRatio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="0"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/swBeamforming"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AI Neural Beamforming (Spatial Array)"
            android:textColor="#FFD54F"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- Dramatic 5-Band EQ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Precision EQ: +/- 12dB"
            android:textColor="#888888"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="200 Hz (Bass)"
            android:textColor="#BBBBBB"
            android:textSize="10sp" />
        <SeekBar
            android:id="@+id/seekBarBand1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="200"
            android:progress="100"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="500 Hz (Low-Mid)"
            android:textColor="#BBBBBB"
            android:textSize="10sp" />
        <SeekBar
            android:id="@+id/seekBarBand2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="200"
            android:progress="100"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1.5 kHz (Speech Detail)"
            android:textColor="#BBBBBB"
            android:textSize="10sp" />
        <SeekBar
            android:id="@+id/seekBarBand3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="200"
            android:progress="100"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3.0 kHz (Clarity)"
            android:textColor="#BBBBBB"
            android:textSize="10sp" />
        <SeekBar
            android:id="@+id/seekBarBand4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="200"
            android:progress="100"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="6.0 kHz (Presence)"
            android:textColor="#BBBBBB"
            android:textSize="10sp" />
        <SeekBar
            android:id="@+id/seekBarBand5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="200"
            android:progress="100"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</ScrollView>