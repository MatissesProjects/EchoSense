<?xml version="1.0" encoding="utf-8"?>
<androidx.wear.widget.BoxInsetLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        app:boxedEdges="all">

        <TextView
            android:id="@+id/tvWatchTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EchoSense Remote"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvWatchStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status: Idle"
            android:textSize="12sp"
            android:layout_marginBottom="12dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerSpeakers"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnToggleWatchMic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Switch Focus"
            android:textSize="10sp" />

        <Button
            android:id="@+id/btnStartBurst"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Burst (30s)"
            android:textSize="10sp"
            android:backgroundTint="#FF9800" />

        <Button
            android:id="@+id/btnToggleWatchStream"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start Stream"
            android:textSize="10sp" />

        <Button
            android:id="@+id/btnRemoteFilters"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Remote Filters"
            android:textSize="10sp"
            android:backgroundTint="#673AB7" />

    </LinearLayout>
</androidx.wear.widget.BoxInsetLayout>